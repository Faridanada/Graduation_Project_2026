# Application
PORT=5000

# AWS Credentials and Region
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# === Disabled: AI service not yet deployed ===
# Re-enable when real AI service is ready and uncomment in reportTrigger.js
# USE_FAKE_REPORTS=true
# AI_SERVICE_URL=http://127.0.0.1:8000
# AI_SERVICE_TOKEN=your-randomly-generated-32-byte-hex-string-here
# PUBLIC_BASE_URL=http://localhost:5000

# S3 bucket for file uploads (profile images, wound images, etc.)
AWS_S3_BUCKET=flexio-smart-uploads

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# S3 bucket for waveform CSV logs
AWS_S3_WAVEFORMS_BUCKET=flexio-smart-waveforms

# MQTT Broker Configuration
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=backend_server
MQTT_PASSWORD=your_backend_mqtt_password
